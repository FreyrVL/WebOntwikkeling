<div class="container p-6 lg:ml-72">
    <%- include("../partials/tableControls", {query: query, table:"transformers"}) %>

    <div class="hidden md:block overflow-x-auto rounded-box border border-base-content/20 bg-base-200">
        <table class="table">

            <thead class="bg-base-300">
                <tr>
                    <th></th>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Age</th>
                    <th>Faction</th>
                    <th>Alive/active</th>
                    <th>Date of birth</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                <% transformers.forEach(transformer => { %>

                    <tr class="view-row hover:bg-base-300">
                        <th>
                            <div class="avatar">
                                <div class="w-12 rounded-xl">
                                    <img src="<%= transformer.imageUrl %>" alt="">
                                </div>
                            </div>
                        </th>

                        <td><%= transformer.id %></td>

                        <td><%= transformer.name %></td>
                        <td><%= transformer.age %></td>
                        <td><%= transformer.faction %></td>

                        <td>
                            <div class="badge <%= transformer.isActive ? 'badge-success' : 'badge-error' %>">
                                <%= transformer.isActive ? 'Yes' : 'No' %>
                            </div>
                        </td>

                        <td><%= transformer.birthDate %></td>

                        <td>
                            <button type="button"
                                    class="edit-btn btn btn-sm btn-primary">
                                <i class="fa-solid fa-pen"></i>
                            </button>
                        </td>

                    </tr>

                    <tr class="edit-row hidden hover:bg-base-300">

                        <td colspan="8">

                            <form method="POST"
                                  action="/<%= transformer.id %>/edit"
                                  class="flex flex-wrap gap-2 items-center">

                                <input name="name"
                                       value="<%= transformer.name %>"
                                       class="input input-sm input-bordered" />

                                <input name="age"
                                       type="number"
                                       value="<%= transformer.age %>"
                                       class="input input-sm input-bordered w-20" />

                                <input name="faction"
                                       value="<%= transformer.faction %>"
                                       class="input input-sm input-bordered" />

                                <select name="isActive"
                                        class="select select-sm select-bordered">

                                    <option value="true" <%= transformer.isActive ? 'selected' : '' %>>
                                        Yes
                                    </option>

                                    <option value="false" <%= !transformer.isActive ? 'selected' : '' %>>
                                        No
                                    </option>

                                </select>

                                <input name="birthDate"
                                       value="<%= transformer.birthDate %>"
                                       class="input input-sm input-bordered" />

                                <button class="btn btn-success btn-sm">
                                    <i class="fa-solid fa-check"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <div class="grid gap-3 md:hidden">
        <% transformers.forEach(transformer => { %>

            <div class="card bg-base-200 border border-base-content/20 shadow-sm transition-colors">

    <div class="card-body p-4 text-sm">

        <!-- VIEW MODE -->
        <div class="view-mode">

            <div class="flex justify-between items-start gap-2">

                <a href="/transformer/<%= transformer.id %>"
                   class="card-title text-base underline decoration-primary">
                    <%= transformer.name %>
                </a>

                <span class="badge badge-primary">
                    #<%= transformer.id %>
                </span>

            </div>

            <div class="grid grid-cols-2 gap-y-2 mt-2">

                <span class="font-semibold">Age:</span>
                <span><%= transformer.age %></span>

                <span class="font-semibold">Faction:</span>
                <span><%= transformer.faction %></span>

                <span class="font-semibold">Active:</span>
                <span><%= transformer.isActive ? 'Yes' : 'No' %></span>

                <span class="font-semibold">Birth:</span>
                <span><%= transformer.birthDate %></span>

            </div>

            <div class="mt-3">
                <button type="button"
                        class="edit-btn btn btn-sm btn-primary w-full">
                    <i class="fa-solid fa-pen"></i> Edit
                </button>
            </div>

        </div>

        <!-- EDIT MODE -->
        <div class="edit-mode hidden">

            <form method="POST"
                  action="/transformers/<%= transformer.id %>/edit"
                  class="flex flex-col gap-2">

                <input name="name"
                       value="<%= transformer.name %>"
                       class="input input-sm input-bordered w-full" />

                <input name="age"
                       type="number"
                       value="<%= transformer.age %>"
                       class="input input-sm input-bordered w-full" />

                <input name="faction"
                       value="<%= transformer.faction %>"
                       class="input input-sm input-bordered w-full" />

                <select name="isActive"
                        class="select select-sm select-bordered w-full">

                    <option value="true" <%= transformer.isActive ? 'selected' : '' %>>Yes</option>
                    <option value="false" <%= !transformer.isActive ? 'selected' : '' %>>No</option>

                </select>

                <input name="birthDate"
                       value="<%= transformer.birthDate %>"
                       class="input input-sm input-bordered w-full" />

                <div class="flex gap-2 mt-2">

                    <button class="btn btn-success btn-sm flex-1">
                        Save
                    </button>

                    <button type="button"
                            class="cancel-btn btn btn-ghost btn-sm flex-1">
                        Cancel
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
        <% }) %>
    </div>

</div>