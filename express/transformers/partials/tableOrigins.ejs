<div class="container p-6 lg:ml-72">
    <%- include("../partials/tableControls", {query: query, table:"origins"}) %>
    <div class="hidden md:block overflow-x-auto rounded-box border border-base-content/20 bg-base-200">
        <table class="table">
            <thead class="bg-base-300">
                <tr>
                    <th></th>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Release year</th>
                    <th>Director</th>
                    <th>Studio</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>

                <% origins.forEach(origin => { %>
                    <tr class="view-row hover:bg-base-300">
                        <th>
                            <div class="avatar">
                                <div class="w-12 rounded-xl">
                                    <img src="<%= origin.imageUrl %>" alt="">
                                </div>
                            </div>
                        </th>
                        <td><%= origin.id %></td>
                        <td><%= origin.title %></td>
                        <td><%= origin.type %></td>
                        <td><%= origin.releaseYear %></td>
                        <td><%= origin.director %></td>
                        <td><%= origin.studio %></td>
                        <td class="flex gap-x-2">
                            <% if (user.role === "ADMIN") { %>
                            <button type="button" class="edit-btn btn btn-sm btn-success">
                                <i class="fa-solid fa-pen"></i>
                            </button>
                            <% } %>
                            <a class="btn btn-sm btn-primary" href="/origin/<%= origin.id %>"><i class="fa-solid fa-eye"></i>View</a>
                        </td>
                    </tr>

                    <tr class="edit-row hidden hover:bg-base-300">
                        <td colspan="8">
                            <form method="POST"
                                  action="/origins/<%= origin.id %>/edit"
                                  class="flex flex-wrap gap-2 items-center">
                                <input name="title"
                                       value="<%= origin.title %>"
                                       class="input input-sm input-bordered" />
                                <input name="type"
                                       value="<%= origin.type %>"
                                       class="input input-sm input-bordered" />
                                <input name="releaseYear"
                                       value="<%= origin.releaseYear %>"
                                       class="input input-sm input-bordered w-24" />
                                <input name="director"
                                       value="<%= origin.director %>"
                                       class="input input-sm input-bordered" />
                                <input name="studio"
                                       value="<%= origin.studio %>"
                                       class="input input-sm input-bordered" />
                                <button class="btn btn-success btn-sm">
                                    <i class="fa-solid fa-check"></i>
                                </button>
                                <button class=".cancel-btn btn btn-error btn-sm">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <div class="grid gap-3 md:hidden">
        <% origins.forEach(origin => { %>
            <div class="card bg-base-200 border border-base-content/20 shadow-sm">
                <div class="card-body p-4 text-sm">
                    <div class="view-mode">
                        <div class="flex justify-between items-start gap-2">
                            <a href="/origin/<%= origin.id %>"
                               class="card-title text-base underline decoration-primary">
                                <%= origin.title %>
                            </a>

                            <span class="badge badge-primary">
                                #<%= origin.id %>
                            </span>
                        </div>
                        <div class="grid grid-cols-2 gap-y-2 mt-2">
                            <span class="font-semibold">Type:</span>
                            <span><%= origin.type %></span>

                            <span class="font-semibold">Release:</span>
                            <span><%= origin.releaseYear %></span>

                            <span class="font-semibold">Director:</span>
                            <span><%= origin.director %></span>

                            <span class="font-semibold">Studio:</span>
                            <span><%= origin.studio %></span>
                        </div>
                        <div class="mt-3">
                            <% if (user.role === "ADMIN") { %>
                            <button type="button"
                                    class="edit-btn btn btn-sm btn-primary w-full">
                                <i class="fa-solid fa-pen"></i> Edit
                            </button>
                            <% } %>
                        </div>
                    </div>

                    <div class="edit-mode hidden">
                        <form method="POST"
                              action="/origins/<%= origin.id %>/edit"
                              class="flex flex-col gap-2">
                            <input name="title"
                                   value="<%= origin.title %>"
                                   class="input input-sm input-bordered w-full" />
                            <input name="type"
                                   value="<%= origin.type %>"
                                   class="input input-sm input-bordered w-full" />
                            <input name="releaseYear"
                                   value="<%= origin.releaseYear %>"
                                   class="input input-sm input-bordered w-full" />
                            <input name="director"
                                   value="<%= origin.director %>"
                                   class="input input-sm input-bordered w-full" />
                            <input name="studio"
                                   value="<%= origin.studio %>"
                                   class="input input-sm input-bordered w-full" />
                            <div class="flex gap-2">
                                <button class="btn btn-success btn-sm flex-1">
                                    Save
                                </button>
                                <button type="button"
                                        class="cancel-btn btn btn-error btn-sm flex-1">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>